# ArcSearch Dev Instance
# Use this .env file for local development and testing.
# It uses a separate database and Qdrant collections to avoid touching production.

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=semantic_searcher_dev

QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333

# Dev mode settings
DISTRIBUTED_MODE=false
HUB_ROLE=standalone
CRAWL_ONLY=false

CRAWLER_WORKERS=10
CRAWLER_RATE_LIMIT=0.5
CRAWLER_MAX_DEPTH=2

RAID_PATH=/tmp/arcsearch-dev/data
WEBINDEX_DIR=/tmp/arcsearch-dev/data

# Lower resource usage for dev
SEARCH_MAX_WORKERS=2
SEARCH_QUEUE_MAX=10
